{
  "name": "mybatis-converter-local",
  "version": "1.0.0",
  "description": "MyBatis SQL Builder → MySQL, 纯本地规则解析，无需 API Key",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"NODE_ENV=development vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.yourname.mybatis-converter",
    "productName": "MyBatis Converter",
    "files": ["dist/**/*", "electron/**/*"],
    "directories": { "output": "release" },
    "mac": { "target": "dmg", "icon": "assets/icon.icns" },
    "win": { "target": "nsis", "icon": "assets/icon.ico" },
    "linux": { "target": "AppImage" }
  }
}
